# ──────────────────────────────────────────────────────────────
# RiskDetector 프론트엔드 환경 변수 예시
# 이 파일을 복사해 .env.local 로 저장하고 값을 채워주세요.
# ──────────────────────────────────────────────────────────────

# 백엔드 API 베이스 URL (슬래시 없이)
# 예: http://localhost:8080
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Mock 모드 (true: 더미 데이터 사용 / false: 실제 API 호출)
# 백엔드 없이 프론트엔드만 개발할 때 true 로 설정
NEXT_PUBLIC_MOCK_MODE=true
