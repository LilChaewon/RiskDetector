# Database (docker-compose 및 Spring Boot에서 공통 사용)
DB_USERNAME=risk_user
DB_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD
POSTGRES_DB=riskdetector

# Google OAuth2
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# JWT (최소 32자 이상의 랜덤 문자열 사용)
JWT_SECRET=CHANGE_ME_MIN_32_CHARS_RANDOM_SECRET_KEY

# CORS (콤마로 여러 origin 구분 가능)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# OAuth2 콜백 URL
OAUTH2_REDIRECT_URI=http://localhost:3000/oauth2/callback

# 프로덕션(HTTPS) 환경에서는 true로 설정
COOKIE_SECURE=false
